---

<style>
    :root {
        --secondary-color: #b8b8b8;
    }

    .cell {
        padding: 20px;
        background-color: var(--bg-color);
        box-shadow: 0 0 0 1px #636569;
        min-width: 0;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(1, 1fr);
    }

    h2 {
        margin-top: 0px;
        color: var(--secondary-color);
        font-size: 0.875rem;
        text-transform: uppercase;
    }

    .content-wrapper {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-inline: auto;
        max-width: var(--max-page-width);
    }

    a {
        white-space: nowrap;
    }

    @media (min-width: 680px) {
        .grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<div class="content-wrapper">
    <h2>Join the chat!</h2>
    <div class="grid">
        <div class="cell">
            <h2>Join the Space</h2>
            <a
                href="https://matrix.to/#/%23matrix-conference-2025%3Amatrix.org"
                >#matrix-conference-2025:matrix.org</a
            >
        </div>
        <div class="cell">
            <h2>Join the General room</h2>
            <a href="https://matrix.to/#/%23general-mc25%3Amatrix.org"
                >#general-mc25:matrix.org</a
            >
        </div>
    </div>
</div>

