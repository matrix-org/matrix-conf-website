---
interface Props {
    talk: CollectionEntry<"talks">;
}

import slugify from '@sindresorhus/slugify';
import Pill from "../components/Pill.astro";
import type { CollectionEntry } from 'astro:content';
import WatchCardContent from "../components/WatchCardContent.astro";
import { Image } from "astro:assets";

const { talk } = Astro.props;
const youtube = talk.data.youtube;
const title = talk.data['Proposal title'];
const talkId = talk.data.ID;
const thumbnailUrl = `/talks/thumbnail_${talkId}.avif`;
const track = talk.data.Track ? talk.data.Track.en : '';
const summary = talk.data.Abstract;
const speakerNames = talk.data['Speaker names'].join(", ");
const room = talk.data.Room.en;
const start = talk.data.Start.split('T')[0];
const slides = talk.data.slides ? `${[start, room, speakerNames, title].join("_")}.pdf` : "";

---

<style lang="scss">
    @use "sass:color";

    .talk-card {
        display: flex;
        border: 1px solid #D2D2D2;
        overflow: clip;
        flex-flow: wrap;

        a {
            text-decoration: none;
        }

        .info-container {
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            color: var(--color-text);

            h2 {
                font-size: 1.25rem;
                line-height: 1.2;
                margin-block: 0;
                display: -webkit-inline-box;
                -webkit-box-orient: vertical;
                -webkit-line-clamp: 3;
                line-clamp: 3;
                overflow: clip;
                height: 3lh;
            }

            p {
                line-height: 1.4;
                margin-block: 0;
                font-size: 1rem;
                display: -webkit-inline-box;
                -webkit-box-orient: vertical;
                -webkit-line-clamp: 3;
                line-clamp: 3;
                overflow: clip;
                height: 3lh;
            }

            .speaker {
                font-size: .75rem;
            }

            .talk-pills {
                display: flex;
                gap: 8px;
                flex-wrap: wrap;
            }
        }

        &:hover {
            box-shadow: 0px 2px 10px #dedede;
        }

        .additional-links {

            p,a {
                padding: 16px 24px;
            }

            a {
                display: flex;
                align-items: center;
                gap: 8px;
                color: var(--link-color)
            }

            border-top: 1px solid #D2D2D2;
            align-self: end;
            width: 100%;

            &:hover {
                background-color: color.adjust(#000, $lightness: 15%);
            }
        }
    }

    .talk-card__thumbnail {
        aspect-ratio: 16/9;
    }
</style>
<div class:list={['talk-card', slugify(track)]}>
    <WatchCardContent youtube={youtube}>
        <Image
            src={thumbnailUrl}
            class="talk-card__thumbnail"
            alt={speakerNames}
            height="900"
            width="1600"
        />
        <div class="info-container">
            <h2>{ title }</h2>
            <p>{ summary }</p>
            <div class="speaker">
                { speakerNames }
            </div>
            <div class="talk-pills">
                {track && <Pill Type="div" label={ track } />}
                <Pill Type="div" label={ room } />
                {!youtube ? <Pill Type="div" label="No Video" /> : ''}
            </div>
        </div>
    </WatchCardContent>
    <div class="additional-links">
        { slides ?
<a href={ `/slides/slides_${talkId}.pdf` } download={ slides } class="slides"><img src="/watch/slides-icon.svg" aria-hidden="true" />View slides</a>
        :
        <p>Slides not available</p>
        }
    </div>
</div>
