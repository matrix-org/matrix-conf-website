---
import PrimaryCta from "./PrimaryCta.astro";
import Logo from "./logo.svg";
import { Image } from "astro:assets";
---

<style>
    .content-wrapper {
        --pattern-height: 64px;
        --hero-columns: 2;
        --logo-width-base: var(--max-page-width);
        --pattern-cell-size: calc(var(--logo-width-base) / (var(--hero-columns) * 10));

        padding: 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    .left-half {
        display: grid;
        place-content: center end;
        background: url("/pattern-2h.svg");

        background-repeat: repeat;
        background-position: top right;
        background-size: calc(var(--logo-width-base)/(var(--hero-columns)*2));
        min-height: round(up, calc(8*var(--pattern-cell-size)), calc(48px*2)); /* height of the logo plus 1 row of pattern around it */
        height: round(up, 100%, calc(48px*2));
    }

    .logo-wrapper {
        place-items: center end;
        margin-block: var(--pattern-cell-size);
        padding-inline-end: clamp(0px,10vw,var(--pattern-cell-size));
    }

    .logo-bg {
        background-color: #000;
        max-width: calc(8*var(--pattern-cell-size));
    }

    h1 {
        display: flex;
        flex-direction: column;
        font-size: 2.5rem;
        margin: 0;
        line-height: 120%;
    }

    .right-half {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        padding: var(--pattern-cell-size);
    }

    .right-half p {
        font-size: 1.125rem;
        margin-bottom: 1.5em;
    }

    @media (max-width: 1100px) {
        .content-wrapper {
            grid-template-columns: 1fr;
        }

        .logo-wrapper {
            padding-inline-end: 0;
        }

        .logo {
            width: calc(4*var(--pattern-cell-size));
        }

        .left-half {
            place-content: center;
            background-image: url("/pattern.svg");
            background-position: calc(50% - 24px);
            min-height: unset;
            height: unset;
        }

        .right-half {
            padding: 2rem 1rem;
        }
    }
</style>
<div class="content-wrapper">
    <div class="left-half">
        <div class="logo-wrapper">
            <div class="logo-bg">
                <Image src={Logo} class="logo" alt="" />
            </div>
        </div>
    </div>
    <div class="right-half">
        <h1>
            <span>20th to 23rd October, 2026</span>
            <span>Malmö, Sweden</span>
        </h1>
        <div>
            <p>
                Come along to see the latest and greatest progress in the Matrix
                world! From huge government deployments to the latest
                innovations, hang out with your peers to share the best
                learning, insights, projects and tips!
            </p>
            <PrimaryCta href="https://cfp.2026.matrix.org/matrix-conference-2026/cfp">Submit Talk Proposals</PrimaryCta>
        </div>
    </div>
</div>
