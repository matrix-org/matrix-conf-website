<style>
    .content-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        column-gap: clamp(20px, calc(10vw - 40px), 60px);
        row-gap: 60px;
        max-width: fit-content;
        margin-top: 1rem;
        margin-inline: auto;
        padding: clamp(2.5rem, 10vw, 5rem) 1.5rem;
        padding-inline: 1.5rem;
    }

    @media (max-width: 800px) {
        /* Number obtained by manually testing */
        .content-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 550px) {
        /* Number obtained by manually testing */
        .content-grid {
            grid-template-columns: 1fr;
        }
    }

    .color-stripe {
        --pattern-size: 5;
        --display-height: 32px;
        background: url("/pattern-2h.svg");
        background-repeat: repeat-x;
        background-position: top left;
        background-size: calc(var(--pattern-size) * var(--display-height));
        height: var(--display-height);
        width: 100%;
    }

    a {
        text-decoration: none;
    }

    ul {
        padding: 0;
        list-style: none;
    }

    li {
        margin-block: 0.5rem;
    }

    h2 {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--secondary-color);
        margin-block: 0 0.7rem;
    }
</style>
<div class="content-grid">
    <div class="information">
        <h2>Information</h2>
        <ul>
            <li><a href="/facts">Venue &amp; Travel</a></li>
            <li><a href="/facts#health-and-safety">Health &amp; Safety</a></li>
            <!--<li><a href="/register">Register</a></li>-->
        </ul>
    </div>
    <div class="contact">
        <h2>Contact</h2>
        <ul>
            <li>
                <a href="mailto:conference@foundation.matrix.org"
                    >conference@foundation.matrix.org</a
                >
            </li>
            <li><a href="https://mastodon.matrix.org/@matrix">Mastodon</a></li>
            <li>
                <a href="https://www.linkedin.com/company/matrix-org/"
                    >LinkedIn</a
                >
            </li>
        </ul>
    </div>
    <div class="legal">
        <h2>Legal</h2>
        <ul>
            <li>
                <a href="https://matrix.org/legal/privacy-notice/"
                    >Privacy Policy</a
                >
            </li>
            <li>
                <a href="https://matrix.org/legal/code-of-conduct/"
                    >Code of Conduct</a
                >
            </li>
        </ul>
    </div>
</div>
<div class="color-stripe"></div>
